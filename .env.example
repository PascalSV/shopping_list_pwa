# Shopping List PWA Environment Variables

# Device/Authentication Token (used as Bearer token)
# Each device should have a unique identifier
DEVICE_TOKEN=my-device-token

# API Base URL (for production deployment)
# API_BASE_URL=https://your-worker.workers.dev

# Cloudflare Worker Configuration
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_API_TOKEN=your-api-token

# D1 Database
# DATABASE_ID=your-database-id
# DATABASE_NAME=shopping_list_db
